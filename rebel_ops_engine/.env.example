# Rebel Operations Engine — Environment Configuration
# Copy this file to .env and fill in real values when integrating with live APIs.

# Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# WhatsApp Business Cloud API (optional — replace mock)
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_FROM_NUMBER=

# Email / SMTP (optional — replace mock)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=rebel-command@example.com

# Google Calendar API (optional — replace mock)
GOOGLE_CALENDAR_CREDENTIALS_PATH=
GOOGLE_CALENDAR_ID=primary

# Slack Notifications (optional — replace mock)
SLACK_WEBHOOK_URL=

# Report Delivery (optional — replace mock)
REPORT_EMAIL_TO=leia@rebelcommand.org

# Security
SECRET_KEY=change-me-in-production
