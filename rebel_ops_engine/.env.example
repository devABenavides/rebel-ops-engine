# Rebel Operations Engine — Environment Configuration
# Copy this file to .env and fill in real values when integrating with live APIs.

# Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Gmail API (free — OAuth 2.0)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Desktop app)
# 3. Download JSON → credentials/gmail_oauth.json
# 4. First run will open browser for OAuth consent
GMAIL_CREDENTIALS_PATH=credentials/gmail_oauth.json

# Google Calendar API (free — OAuth 2.0)
# Same project as Gmail — add Calendar API, create credentials/calendar_oauth.json
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials/calendar_oauth.json
GOOGLE_CALENDAR_ID=primary

# Meta WhatsApp Cloud API (free — 1,000 conversations/month)
# 1. Go to https://developers.facebook.com/apps/
# 2. Create app → Business → WhatsApp
# 3. Get Phone Number ID + Access Token from WhatsApp > API Setup
# 4. Set your verify token (custom string)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=rebel_ops_verify

# ClickUp API (free tier)
# 1. Go to Settings > Apps > API Token
# 2. Create a token
# 3. Get List ID from the URL of your list (/list/{list_id})
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=

# Discord Notifications (free — unlimited webhooks)
# Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# Calendar
TIMEZONE=America/Bogota

# Webhook shared secret — if set, POST webhooks require X-Webhook-Secret header
WEBHOOK_SECRET=

# Persistence
DATABASE_PATH=rebel_ops.db

# Security
SECRET_KEY=change-me-in-production
